{
  "name": "@wex/components-react",
  "version": "0.2.0",
  "description": "WEX Design System React components - theme-agnostic UI components built on Radix UI and shadcn",
  "type": "module",
  "main": "./index.ts",
  "module": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": {
      "types": "./index.ts",
      "import": "./index.ts",
      "require": "./index.ts"
    },
    "./actions": {
      "types": "./actions/index.ts",
      "import": "./actions/index.ts",
      "require": "./actions/index.ts"
    },
    "./form-inputs": {
      "types": "./form-inputs/index.ts",
      "import": "./form-inputs/index.ts",
      "require": "./form-inputs/index.ts"
    },
    "./form-structure": {
      "types": "./form-structure/index.ts",
      "import": "./form-structure/index.ts",
      "require": "./form-structure/index.ts"
    },
    "./layout": {
      "types": "./layout/index.ts",
      "import": "./layout/index.ts",
      "require": "./layout/index.ts"
    },
    "./data-display": {
      "types": "./data-display/index.ts",
      "import": "./data-display/index.ts",
      "require": "./data-display/index.ts"
    },
    "./feedback": {
      "types": "./feedback/index.ts",
      "import": "./feedback/index.ts",
      "require": "./feedback/index.ts"
    },
    "./navigation": {
      "types": "./navigation/index.ts",
      "import": "./navigation/index.ts",
      "require": "./navigation/index.ts"
    },
    "./overlays": {
      "types": "./overlays/index.ts",
      "import": "./overlays/index.ts",
      "require": "./overlays/index.ts"
    },
    "./tailwind-preset": {
      "types": "./tailwind-preset.d.ts",
      "import": "./tailwind-preset.js",
      "require": "./tailwind-preset.js"
    }
  },
  "files": [
    "*.tsx",
    "*.ts",
    "actions/",
    "form-inputs/",
    "form-structure/",
    "layout/",
    "data-display/",
    "feedback/",
    "navigation/",
    "overlays/",
    "hooks/",
    "lib/",
    "index.ts",
    "tailwind-preset.js",
    "tailwind-preset.d.ts",
    "README.md"
  ],
  "scripts": {
    "build": "cd ../.. && node scripts/build-tokens.cjs && cd packages/wex-components-react && ../../node_modules/.bin/tsup",
    "dev": "node_modules/.bin/tsup --watch || npx tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests"
  },
  "peerDependencies": {
    "@wex/design-tokens": "0.2.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwindcss": "^3.4.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.562.0",
    "react-day-picker": "^9.13.0",
    "react-resizable-panels": "^4.0.10",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.4",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.0.0",
    "typescript": "~5.9.3"
  },
  "keywords": [
    "wex",
    "design-system",
    "react",
    "components",
    "radix",
    "shadcn",
    "ui"
  ],
  "author": "WEX Design System Team",
  "license": "UNLICENSED",
  "private": false
}

