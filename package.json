{
  "name": "cxr-ux-wex",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "predev": "node scripts/build-tokens.cjs",
    "install:deps": "node scripts/npm-install-with-token.cjs",
    "dev": "bash -c 'unset npm_config_prefix && export NVM_DIR=\"$HOME/.nvm\" && if [ -s \"$NVM_DIR/nvm.sh\" ]; then . \"$NVM_DIR/nvm.sh\" && (nvm use > /dev/null 2>&1 || true); fi; exec node scripts/dev-vite.mjs'",
    "dev:auto": "bash scripts/dev.sh",
    "build": "node scripts/build-tokens.cjs && tsc -b && vite build",
    "postbuild": "cp dist/index.html dist/404.html",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@nivo/bar": "^0.99.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@wexinc-healthbenefits/ben-ui-kit": "0.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "culori": "^4.0.2",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.562.0",
    "motion": "^12.38.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.68.0",
    "react-qr-code": "^2.0.18",
    "react-router-dom": "^7.11.0",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
